<div style="max-width: 650px; margin: 0 auto; padding: 20px; font-family: sans-serif;"> 
  
  <!-- Header Bar --> 
  <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #eaeaea; padding-bottom: 14px; margin-bottom: 20px; flex-wrap: wrap; gap: 12px;"> 
    <div style="display: flex; align-items: center; gap: 12px;">
      <%= link_to "← Dashboard", authenticated_root_path, style: "font-size: 14px; color: #4b5563; text-decoration: none; font-weight: 500; background: #f3f4f6; padding: 6px 12px; border-radius: 6px;" %> 
      <h2 style="margin: 0; color: #111827; font-size: 22px; font-weight: 700;">Notifications</h2> 
    </div>

    <!-- DYNAMIC CLEAR BUTTON: Only displays if notifications are active -->
    <% if @notifications.any? %>
      <%= button_to clear_all_notifications_path, method: :delete, data: { confirm: "Are you sure you want to clear your entire notification inbox?" }, style: "font-size: 13px; color: #ef4444; background: #fef2f2; border: 1px solid #fee2e2; padding: 6px 14px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s;", onmouseover: "this.style.backgroundColor='#fee2e2'", onmouseout: "this.style.backgroundColor='#fef2f2'" do %>
        🗑️ Clear All
      <% end %>
    <% end %>
  </div> 

  <!-- Activity Stream Feed --> 
  <div style="display: flex; flex-direction: column; gap: 12px;"> 
    <% if @notifications.any? %> 
      <% @notifications.each do |notification| %> 
        
        <%# Determine indicator icon and messaging copy based on action strings %> 
        <% icon, message_suffix = case notification.action %> 
        <% when 'liked_post' then ["❤️", "liked your update post."] %> 
        <% when 'commented_on_post' then ["💬", "commented on your update post."] %> 
        <%# UPDATED: Replaced follow_request with friend_request to match your new architecture %>
        <% when 'friend_request' then ["👥", "sent you a friend request invitation."] %> 
        <% else ["✨", "interacted with your profile."] %> 
        <% end %> 

        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; box-shadow: 0 1px 2px rgba(0,0,0,0.02); display: flex; align-items: center; justify-content: space-between; gap: 12px; <%= 'border-left: 4px solid #2563eb;' if notification.read_at_was.nil? %>"> 
          <div style="display: flex; align-items: center; gap: 12px; min-width: 0; flex-grow: 1;"> 
            <span style="font-size: 18px; flex-shrink: 0;"><%= icon %></span> 
            <div style="font-size: 14px; color: #374151; min-width: 0; overflow: hidden; text-overflow: ellipsis; flex-grow: 1;"> 
              <%= link_to (notification.actor.name.presence || notification.actor.email), user_path(notification.actor), style: "font-weight: bold; color: #2563eb; text-decoration: none;" %> 
              <span style="color: #4b5563;"><%= message_suffix %></span> 
              <span style="font-size: 11px; color: #9ca3af; display: block; margin-top: 4px;"><%= time_ago_in_words(notification.created_at) %> ago</span> 
            </div> 
          </div> 

          <%# Provide contextual routing links based on item contexts %> 
          <% if %w[liked_post commented_on_post].include?(notification.action) %> 
            <%= link_to "View Post →", authenticated_root_path, style: "font-size: 12px; color: #2563eb; text-decoration: none; font-weight: 500; white-space: nowrap;" %> 
          <% else %> 
            <%# Redirects to profile page where your newly added sidebar requests can be managed %>
            <%= link_to "View Request →", profile_path(current_user.profile), style: "font-size: 12px; color: #2563eb; text-decoration: none; font-weight: 500; white-space: nowrap;" if current_user.profile %> 
          <% end %> 
        </div> 
      <% end %> 
    <% else %> 
      <p style="color: #6b7280; font-style: italic; text-align: center; padding: 40px 0; background: white; border: 1px dashed #d1d5db; border-radius: 12px; font-size: 14px;">Your notification inbox stream is empty.</p> 
    <% end %> 
  </div> 
</div>
