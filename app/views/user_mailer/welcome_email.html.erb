<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
</head>
<body style="font-family: sans-serif; background-color: #f9fafb; padding: 20px; color: #111827; margin: 0;">

  <div style="max-width: 500px; margin: 20px auto; background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 30px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
    
    
    <div style="font-size: 24px; font-weight: 700; color: #2563eb; margin-bottom: 20px; border-bottom: 2px solid #f3f4f6; padding-bottom: 12px;">
      OdinBook
    </div>

    <h2 style="margin-top: 0; color: #111827; font-size: 20px;">Account Created Successfully!</h2>
    
    <p style="font-size: 15px; color: #374151; line-height: 1.5;">
      Hi <strong><%= @display_name %></strong>,
    </p>
    
    <p style="font-size: 14px; color: #4b5563; line-height: 1.5;">
      Welcome to OdinBook! Your account is active, secure, and ready to go. You can now publish updates, leave text replies on threads, and follow friends.
    </p>

    <!-- Call to Action Routing Button -->
    <div style="margin: 30px 0; text-align: center;">
      <%= link_to "Go to Your Dashboard", "http://localhost:3000", style: "background-color: #2563eb; color: white; padding: 12px 24px; font-size: 14px; font-weight: 600; text-decoration: none; border-radius: 8px; display: inline-block; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" %>
    </div>

    <p style="font-size: 14px; color: #4b5563; line-height: 1.5; margin-bottom: 25px;">
      To customize your profile image avatar picture or add a bio description summary, head over to your profile settings.
    </p>

    <div style="font-size: 11px; color: #9ca3af; border-top: 1px solid #e5e7eb; padding-top: 15px;">
      Sent to: <%= @user.email %><br>
      You are receiving this because you registered an account on OdinBook.
    </div>
    
  </div>

</body>
</html>